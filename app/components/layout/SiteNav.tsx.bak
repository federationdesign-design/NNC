"use client";

import { useState, useEffect } from "react";
import Link from "next/link";
import Image from "next/image";
import styles from "./SiteNav.module.css";

const NAV_LINKS = [
  { label: "Our Homes",    href: "/homes" },
  { label: "Our Approach", href: "/approach" },
  { label: "Senior Team",  href: "/team" },
  { label: "News",         href: "/news" },
  { label: "Contact",      href: "/contact" },
];

interface SiteNavProps {
  transparent?: boolean;
}

export default function SiteNav({ transparent = false }: SiteNavProps) {
  const [solid, setSolid] = useState(!transparent);
  const [menuOpen, setMenuOpen] = useState(false);

  useEffect(() => {
    if (!transparent) {
      setSolid(true);
      return;
    }
    // Read solid state from hero scroll-fade (HomeHero writes dataset.heroSolid)
    const onScroll = () => {
      const heroSolid = document.documentElement.dataset.heroSolid;
      if (heroSolid !== undefined) {
        setSolid(heroSolid === "1");
      } else {
        setSolid(window.scrollY > 60);
      }
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    return () => window.removeEventListener("scroll", onScroll);
  }, [transparent]);

  // close menu on route change / resize
  useEffect(() => {
    const close = () => setMenuOpen(false);
    window.addEventListener("resize", close, { passive: true });
    return () => window.removeEventListener("resize", close);
  }, []);

  return (
    <nav className={`${styles.nav} ${solid ? styles.solid : styles.transparent}`}
         aria-label="Main navigation">
      <div className={styles.inner}>
        <Link href="/" className={styles.logo} aria-label="Nurturing Nests home">
          <Image
            src="/header-logo.svg"
            alt="Nurturing Nests"
            width={120}
            height={56}
            priority
            className={styles.logoImg}
          />
        </Link>

        <ul className={styles.links} role="list">
          {NAV_LINKS.map((l) => (
            <li key={l.href}>
              <Link href={l.href} className={styles.link}>{l.label}</Link>
            </li>
          ))}
        </ul>

        <Link href="/contact" className={styles.ctaDesktop}>
          Get in touch
        </Link>

        <button
          className={styles.hamburger}
          aria-label={menuOpen ? "Close menu" : "Open menu"}
          aria-expanded={menuOpen}
          onClick={() => setMenuOpen((v) => !v)}
        >
          <span className={`${styles.bar} ${menuOpen ? styles.barTop : ""}`} />
          <span className={`${styles.bar} ${menuOpen ? styles.barMid : ""}`} />
          <span className={`${styles.bar} ${menuOpen ? styles.barBot : ""}`} />
        </button>
      </div>

      {menuOpen && (
        <div className={styles.mobileMenu} role="dialog" aria-modal="true"
             aria-label="Mobile navigation">
          <ul role="list">
            {NAV_LINKS.map((l) => (
              <li key={l.href}>
                <Link href={l.href} className={styles.mobileLink}
                      onClick={() => setMenuOpen(false)}>
                  {l.label}
                </Link>
              </li>
            ))}
            <li>
              <Link href="/contact" className={styles.mobileCta}
                    onClick={() => setMenuOpen(false)}>
                Get in touch
              </Link>
            </li>
          </ul>
        </div>
      )}
    </nav>
  );
}
