/* HomeHeroV2.module.css */

.root {
  display: flex;
  flex-direction: column;
  min-height: 100dvh;
}

/* ===== LEFT PANEL ===== */
.panel {
  background: #fff;
  width: 100%;
  padding: 32px 24px;
  border-right: 1px solid var(--color-line);
  display: flex;
  flex-direction: column;
}

.logoArea {
  display: flex;
  justify-content: center;
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--color-line);
}

.logo {
  height: 110px;
  width: auto;
  display: block;
  object-fit: contain;
}

.cards { display: flex; flex-direction: column; }

/* ===== RIGHT HERO ===== */
.heroArea {
  position: relative;
  flex: 1;
  min-height: 70dvh;
  display: flex;
  flex-direction: column;
  background: var(--color-brand-dark);
  overflow: hidden;
}

.heroBg { position: absolute; inset: 0; z-index: 0; }

.heroBgImg {
  object-fit: cover;
  object-position: center top;
  opacity: 0;
  transition: opacity 1s ease;
}

.heroBgImgActive { opacity: 1; }

.brandOverlay {
  position: absolute;
  inset: 0;
  background: rgba(15, 55, 90, 0.5);
  z-index: 1;
}

.scrollOverlay {
  position: absolute;
  inset: 0;
  background: #000;
  opacity: 0;
  z-index: 2;
  pointer-events: none;
  transition: none;
}

/* Header nav */
.heroNav {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid rgba(255,255,255,0.15);
  flex-wrap: wrap;
}

.heroNavLinks { display: flex; align-items: stretch; }

.heroNavLink {
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  color: rgba(255,255,255,0.88);
  text-decoration: none;
  padding: 16px 22px;
  transition: color var(--t-fast), background var(--t-fast);
  display: flex;
  align-items: center;
}

.heroNavLink:hover {
  color: #fff;
  background: rgba(255,255,255,0.08);
}

.heroNavActions {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 16px;
}

.referralBtn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--color-ink);
  background: #fff;
  padding: 10px 20px;
  border-radius: 999px;
  text-decoration: none;
  transition: background var(--t-fast);
  white-space: nowrap;
}

.referralBtn:hover { background: var(--color-brand-light); }

.callBtn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  color: rgba(255,255,255,0.88);
  text-decoration: none;
  padding: 10px 14px;
  transition: color var(--t-fast);
  white-space: nowrap;
}

.callBtn:hover { color: #fff; }

/* Hero content */
.heroContent {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 40px 40px 48px;
}

.heroTopLeft { align-self: flex-start; max-width: 340px; }

.heroSubtitle {
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: clamp(0.95rem, 1.5vw, 1.1rem);
  font-weight: 500;
  line-height: 1.65;
  color: rgba(255,255,255,0.82);
  margin: 0;
}

.heroBottom {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.heroHeading {
  font-family: var(--font-mali), cursive;
  font-size: clamp(2rem, 4.5vw, 4rem);
  font-weight: 700;
  line-height: 1.05;
  color: #fff;
  margin: 0;
  text-align: right;
}

.heroBottomRow {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}

/* ===== STACKED OVERLAY CARDS ===== */
.stackedCards {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-width: 520px;
}

/* Card 1 - dark navy Ofsted card */
.ofstedCard {
  background: #1e1e4a;
  border-radius: var(--radius-lg);
  padding: 28px 32px;
  display: flex;
  flex-direction: row;
  gap: 28px;
  align-items: flex-start;
}

.ofstedCardLeft {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  min-width: 130px;
}

.ofstedCardRight {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.ofstedCardText {
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.88rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.85);
  margin: 0;
}

/* Card 2 - brand blue NNC card */
.nncCard {
  background: var(--color-brand);
  border-radius: var(--radius-lg);
  padding: 28px 32px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.nncCardLogo {
  filter: brightness(0) invert(1);
  height: 44px;
  width: auto;
  object-fit: contain;
  object-position: left;
}

.nncCardText {
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.88rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.88);
  margin: 0;
}

/* Shared card pill buttons */
.cardBtn {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  border: 1.5px solid rgba(255,255,255,0.5);
  padding: 14px 24px;
  border-radius: 999px;
  transition: border-color var(--t-fast), background var(--t-fast);
  min-width: 200px;
}

.cardBtn:hover {
  border-color: #fff;
  background: rgba(255,255,255,0.1);
}

.cardBtnOutline {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  border: 1.5px solid rgba(255,255,255,0.5);
  padding: 14px 24px;
  border-radius: 999px;
  transition: border-color var(--t-fast), background var(--t-fast);
  align-self: flex-start;
  min-width: 200px;
}

.cardBtnOutline:hover {
  border-color: #fff;
  background: rgba(255,255,255,0.15);
}

/* Main CTA */
.ctaBtn {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  border: 1.5px solid rgba(255,255,255,0.6);
  padding: 16px 32px;
  border-radius: 999px;
  transition: border-color var(--t-fast), background var(--t-fast);
  white-space: nowrap;
  align-self: flex-end;
}

.ctaBtn:hover {
  border-color: #fff;
  background: rgba(255,255,255,0.1);
}

/* Slide indicators */
.slideIndicators {
  position: absolute;
  bottom: 20px;
  right: 40px;
  z-index: 10;
  display: flex;
  gap: 8px;
}

.slideDot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  border: none;
  cursor: pointer;
  transition: background var(--t-fast);
  padding: 0;
}

.slideDotActive { background: #fff; }

/* ===== DESKTOP ===== */
@media (min-width: 900px) {
  .root {
    flex-direction: row;
    height: 100dvh;
    overflow: hidden;
  }

  .panel {
    width: 420px;
    min-width: 380px;
    flex-shrink: 0;
    height: 100dvh;
    overflow-y: auto;
    padding: 32px 28px;
  }

  .heroArea {
    flex: 1;
    height: 100dvh;
    min-height: 100dvh;
  }

  .heroContent { padding: 40px 56px 52px; }
  .heroTopLeft { max-width: 360px; }
}

@media (min-width: 1240px) {
  .panel { width: 460px; }
  .heroContent { padding: 40px 72px 60px; }
  .stackedCards { max-width: 560px; }
}
