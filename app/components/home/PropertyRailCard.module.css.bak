/* PropertyRailCard.module.css - full-width stacked image, 25px radius */

.cardWrapper {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.card {
  display: flex;
  flex-direction: column;
  width: 100%;
  text-align: left;
  background: transparent;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: background var(--t-fast);
}

.card:hover .media { opacity: 0.92; }

/* Full-width image with 25px radius */
.media {
  position: relative;
  width: 100%;
  height: 170px;
  overflow: hidden;
  background: var(--color-brand-light);
  flex-shrink: 0;
  border-radius: 25px;
  transition: opacity var(--t-fast);
}

.img {
  object-fit: cover;
  border-radius: 25px;
}

.status {
  position: absolute;
  top: 10px;
  left: 10px;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 9px;
  border-radius: 20px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
}

.statusOpen     { background: #d1fae5; color: #065f46; }
.statusProposed { background: rgba(255,255,255,0.9); color: var(--color-brand-dark); }
.statusDev      { background: rgba(255,255,255,0.7); color: var(--color-muted); }

.info {
  display: flex;
  flex-direction: column;
  gap: 7px;
  padding: 14px 4px 10px;
}

/* 33% larger text */
.name {
  font-family: var(--font-mali), cursive;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0;
}

.meta {
  display: flex;
  gap: 16px;
  align-items: center;
}

.metaItem {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.88rem;
  color: var(--color-muted);
}

.summary {
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.92rem;
  line-height: 1.55;
  color: var(--color-muted);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* View home button */
.viewHomeRow {
  padding: 8px 4px 12px;
}

.viewHomeBtn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-jakarta), system-ui, sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--color-brand);
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: color var(--t-fast);
}

.viewHomeBtn:hover { color: var(--color-brand-dark); }

/* Dividing line between properties */
.divider {
  height: 1px;
  background: var(--color-line);
  margin: 0 0 16px 0;
}

/* Last card divider hidden */
.cardWrapper:last-child .divider {
  display: none;
}
