/* PropertyRailCard.module.css */

.card {
  display: flex;
  flex-direction: row;
  gap: 12px;
  width: 100%;
  text-align: left;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--color-line);
  padding: 14px 0;
  cursor: pointer;
  transition: background var(--t-fast);
}

.card:hover {
  background: var(--color-brand-light);
  padding-left: 8px;
  padding-right: 8px;
  border-radius: var(--radius-sm);
}

.media {
  position: relative;
  width: 72px;
  min-width: 72px;
  height: 56px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--color-brand-light);
  flex-shrink: 0;
}

.img { object-fit: cover; }

.info {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
  flex: 1;
}

.titleRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.name {
  font-family: var(--font-display);
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.status {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 2px 6px;
  border-radius: 20px;
  flex-shrink: 0;
}

.statusOpen     { background: #d1fae5; color: #065f46; }
.statusProposed { background: var(--color-brand-light); color: var(--color-brand-dark); }
.statusDev      { background: #f3f4f6; color: var(--color-muted); }

.meta {
  display: flex;
  gap: 12px;
  align-items: center;
}

.metaItem {
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-body);
  font-size: 0.72rem;
  color: var(--color-muted);
}

.summary {
  font-family: var(--font-body);
  font-size: 0.75rem;
  line-height: 1.5;
  color: var(--color-muted);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
