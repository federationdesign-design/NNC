/* TeamBand.module.css - full bleed, ANT-style */

.section {
  background: var(--color-surface);
  border-top: 1px solid var(--color-line);
  overflow: hidden;
}

.inner {
  display: flex;
  flex-direction: column;
  width: 100%;
}

/* Left header */
.header {
  padding: var(--space-6) 20px var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  border-bottom: 1px solid var(--color-line);
}

.eyebrow {
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-brand);
  margin: 0;
}

.heading {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 3vw, 1.75rem);
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.3;
  max-width: 32ch;
  margin: 0;
}

.arrowCta {
  display: inline-flex;
  color: var(--color-ink);
  text-decoration: none;
  width: 44px;
  height: 44px;
  transition: color var(--t-fast);
}

.arrowCta:hover { color: var(--color-brand); }

/* Full-bleed scrolling track */
.track {
  display: flex;
  flex-direction: row;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  touch-action: pan-x;
  scrollbar-width: none;
  /* No padding - cards go edge to edge */
}

.track::-webkit-scrollbar { display: none; }

/* Cards */
.card {
  flex-shrink: 0;
  width: 300px;
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  scroll-snap-align: start;
  border-right: 1px solid var(--color-line);
  border-top: 1px solid var(--color-line);
}

/* Contact icons */
.contactIcons {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: var(--space-2);
}

.iconBtn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--color-brand);
  text-decoration: none;
  transition: color var(--t-fast);
}

.iconBtn:hover { color: var(--color-brand-dark); }

.iconBtn span {
  border-bottom: 1px solid transparent;
  transition: border-color var(--t-fast);
}

.iconBtn:hover span { border-color: var(--color-brand-dark); }

/* Avatar */
.avatar {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-brand-light);
  border: 2px solid var(--color-line);
  flex-shrink: 0;
  margin-top: var(--space-1);
}

.avatarImg { object-fit: cover; }

.name {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0;
}

.role {
  font-family: var(--font-body);
  font-size: 0.82rem;
  color: var(--color-muted);
  margin: 0;
}

.bio {
  font-family: var(--font-body);
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--color-ink);
  margin: 0;
  flex: 1;
}

.viewBtn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-body);
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--color-ink);
  text-decoration: none;
  border: 1.5px solid var(--color-ink);
  padding: 10px 20px;
  border-radius: 999px;
  margin-top: var(--space-2);
  transition: background var(--t-fast), color var(--t-fast);
  align-self: flex-start;
}

.viewBtn:hover {
  background: var(--color-ink);
  color: #fff;
}

/* Desktop: side by side, full bleed */
@media (min-width: 900px) {
  .inner {
    flex-direction: row;
    align-items: stretch;
  }

  .header {
    width: 300px;
    min-width: 280px;
    flex-shrink: 0;
    padding: var(--space-7) var(--space-5) var(--space-7) 60px;
    border-bottom: none;
    border-right: 1px solid var(--color-line);
    justify-content: flex-start;
    position: sticky;
    top: 0;
    align-self: flex-start;
  }

  .track {
    flex: 1;
    border-top: none;
  }

  .card {
    width: 320px;
    border-top: none;
    padding: var(--space-7) var(--space-5);
  }

  /* First card no left border - goes to edge */
  .card:first-child {
    border-left: none;
  }
}

@media (min-width: 1024px) {
  .card { width: 340px; }
}
