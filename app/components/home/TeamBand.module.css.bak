/* TeamBand.module.css - ANT-style horizontal scroll band */

.section {
  background: var(--color-surface);
  border-top: 1px solid var(--color-line);
}

.inner {
  max-width: var(--container);
  margin: 0 auto;
  display: flex;
  flex-direction: column;
}

/* ---- Left pinned header ---- */
.header {
  padding: var(--space-6) 20px var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  border-bottom: 1px solid var(--color-line);
}

.eyebrow {
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-brand);
  margin: 0;
}

.heading {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 3vw, 1.75rem);
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.3;
  max-width: 32ch;
  margin: 0;
}

.arrowCta {
  display: inline-flex;
  color: var(--color-ink);
  text-decoration: none;
  width: 44px;
  height: 44px;
  transition: color var(--t-fast);
}

.arrowCta:hover {
  color: var(--color-brand);
}

/* ---- Scrolling track ---- */
.track {
  display: flex;
  flex-direction: row;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  touch-action: pan-x;
  scrollbar-width: none;
}

.track::-webkit-scrollbar {
  display: none;
}

/* ---- Individual card ---- */
.card {
  flex-shrink: 0;
  width: 280px;
  padding: var(--space-5) var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  scroll-snap-align: start;
  border-top: 1px solid var(--color-line);
}

.cardTop {
  margin-bottom: var(--space-2);
}

.avatar {
  position: relative;
  width: 72px;
  height: 72px;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-brand-light);
  border: 2px solid var(--color-line);
  flex-shrink: 0;
}

.avatarImg {
  object-fit: cover;
}

.name {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0;
}

.role {
  font-family: var(--font-body);
  font-size: 0.82rem;
  color: var(--color-muted);
  margin: 0;
}

.bio {
  font-family: var(--font-body);
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--color-ink);
  margin: 0;
  flex: 1;
}

/* Pill button matching ANT style */
.viewBtn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-body);
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--color-ink);
  text-decoration: none;
  border: 1.5px solid var(--color-ink);
  padding: 10px 20px;
  border-radius: 999px;
  margin-top: var(--space-2);
  transition: background var(--t-fast), color var(--t-fast);
  align-self: flex-start;
}

.viewBtn:hover {
  background: var(--color-ink);
  color: #fff;
}

/* ---- Desktop: side by side ---- */
@media (min-width: 900px) {
  .inner {
    flex-direction: row;
    align-items: stretch;
  }

  .header {
    width: 300px;
    min-width: 280px;
    flex-shrink: 0;
    padding: var(--space-7) var(--space-5);
    border-bottom: none;
    border-right: 1px solid var(--color-line);
    justify-content: flex-start;
    position: sticky;
    top: var(--nav-height);
    align-self: flex-start;
  }

  .track {
    flex: 1;
    border-top: none;
    border-left: none;
  }

  .card {
    width: 300px;
    border-top: none;
    padding: var(--space-7) var(--space-5);
  }
}

@media (min-width: 1024px) {
  .header { width: 320px; padding: var(--space-7) var(--space-6); }
  .card   { width: 320px; padding: var(--space-7) var(--space-5); }
}
