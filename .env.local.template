# Adapt Ability - environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# GTM (already set)
NEXT_PUBLIC_GTM_ID=GTM-KWFKMZLW

# GA4 Measurement ID - find in GA4 > Admin > Data Streams > your stream
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=REPLACE_WITH_GA_ID

# Stripe
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Database (Neon or Supabase - set up in Phase 5)
DATABASE_URL=

# Resend (transactional email - set up in Phase 5)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=enquiries@myadaptability.co.uk
